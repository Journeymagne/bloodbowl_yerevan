{
  "name": "bloodbowl-sevens-reference",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "import:gata": "python scripts/import-gata-content.py",
    "standardize": "node scripts/standardize-content.mjs",
    "build": "node scripts/build-data.mjs && node scripts/build-site.mjs",
    "i18n:check": "node scripts/check-i18n-glossary.mjs",
    "dev": "node scripts/build-data.mjs && node scripts/serve.mjs",
    "server": "node server/server.mjs",
    "start": "npm run build && node server/server.mjs",
    "site:up": "npm start",
    "postgres:up": "docker-compose up -d",
    "postgres:down": "docker-compose down",
    "postgres:reset": "docker-compose down -v"
  },
  "dependencies": {
    "pg": "^8.13.1"
  }
}
